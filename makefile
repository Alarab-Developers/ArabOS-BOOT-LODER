# ====================================
# المتغيرات الأساسية
# ====================================
EFIINC=/usr/include/efi
EFILIB=/usr/lib

BOOTX64=BOOTX64.EFI
ESP=esp.img
ISO=ArabOS.iso

OVMF_CODE=/usr/share/OVMF/OVMF_CODE_4M.fd
OVMF_VARS=OVMF_VARS.fd

CC=gcc
LD=ld

# إعدادات اللغة العربية
export LANG=ar_EG.UTF-8
export LC_ALL=ar_EG.UTF-8

# ====================================
# إعدادات المترجم
# ====================================
CFLAGS = \
	-I$(EFIINC) \
	-I$(EFIINC)/x86_64 \
	-I./المحركات \
	-fpic \
	-ffreestanding \
	-fshort-wchar \
	-mno-red-zone \
	-maccumulate-outgoing-args \
	-finput-charset=UTF-8 \
	-fexec-charset=UTF-8 \
	-Wall

LDFLAGS = \
	-nostdlib \
	-znocombreloc \
	-T /usr/lib/elf_x86_64_efi.lds \
	-shared \
	-Bsymbolic

# ====================================
# الأهداف الرئيسية
# ====================================
all: $(BOOTX64)

# ====================================
# تجميع المصادر
# ====================================
محرك_الاقلاع.o: المحركات/محرك_الاقلاع.c المحركات/محرك_الاقلاع.h
	$(CC) $(CFLAGS) -c $< -o $@

محرك_القائمة.o: المحركات/محرك_القائمة.c المحركات/محرك_القائمة.h
	$(CC) $(CFLAGS) -c $< -o $@

محرك_التمهيد.o: المحركات/محرك_التمهيد.c المحركات/محرك_التمهيد.h
	$(CC) $(CFLAGS) -c $< -o $@

محرك_ادارة_الصور.o: المحركات/محرك_ادارة_الصور.c المحركات/محرك_ادارة_الصور.h
	$(CC) $(CFLAGS) -c $< -o $@

محمل_النواه.o: المحركات/محمل_النواه.c المحركات/محمل_النواه.h
	$(CC) $(CFLAGS) -c $< -o $@

البوابة.o: البوابة.c المحركات/محرك_الاقلاع.h
	$(CC) $(CFLAGS) -c $< -o $@

# ====================================
# ربط مكتبة EFI المشتركة
# ====================================
محرك_الاقلاع.so: محرك_الاقلاع.o محرك_القائمة.o محرك_ادارة_الصور.o محرك_التمهيد.o محمل_النواه.o البوابة.o
	$(LD) \
		$(LDFLAGS) \
		/usr/lib/crt0-efi-x86_64.o \
		محرك_الاقلاع.o \
		محرك_القائمة.o \
		محرك_التمهيد.o \
		محرك_ادارة_الصور.o \
		محمل_النواه.o \
		البوابة.o \
		-L$(EFILIB) \
		-lefi \
		-lgnuefi \
		-o محرك_الاقلاع.so

# ====================================
# تحويل ELF -> EFI
# ====================================
$(BOOTX64): محرك_الاقلاع.so
	objcopy \
		-j .text \
		-j .sdata \
		-j .data \
		-j .dynamic \
		-j .dynsym \
		-j .rel \
		-j .rela \
		-j .reloc \
		--target=efi-app-x86_64 \
		محرك_الاقلاع.so \
		$(BOOTX64)

# ====================================
# بناء صورة FAT لنظام EFI
# ====================================
$(ESP): $(BOOTX64)
	rm -f $(ESP)

	dd if=/dev/zero of=$(ESP) bs=1M count=64
	mkfs.vfat -F 32 -n "ArabOS" $(ESP)

	# إنشاء هيكل المجلدات داخل الصورة
	mmd -i $(ESP) ::EFI
	mmd -i $(ESP) ::EFI/BOOT

	# نسخ ملف BOOTX64.EFI
	mcopy -i $(ESP) \
		$(BOOTX64) \
		::EFI/BOOT/BOOTX64.EFI

	# إنشاء مجلد اعدادات_القائمة داخل الصورة (تم نقله إلى المقلع)
	mmd -i $(ESP) ::المقلع
	mmd -i $(ESP) ::المقلع/اعدادات_القائمة

	# نسخ ملف القائمة من المسار الجديد
	mcopy -i $(ESP) \
		المقلع/اعدادات_القائمة/القائمة.نص \
		::المقلع/اعدادات_القائمة/القائمة.نص

	# نسخ خلفية الشاشة الرئيسية
	mcopy -i $(ESP) \
		"المقلع/اعدادات_القائمة/خلفية.png" \
		"::المقلع/اعدادات_القائمة/خلفية.png"

	# نسخ خلفية القائمة
	mcopy -i $(ESP) \
		"المقلع/اعدادات_القائمة/نافذه.png" \
		"::المقلع/اعدادات_القائمة/نافذه.png"

	# نسخ شريط العنوان (إذا وجد)
	- mcopy -i $(ESP) \
		"المقلع/اعدادات_القائمة/شريط.png" \
		"::المقلع/اعدادات_القائمة/شريط.png"

	# نسخ صورة التحديد (إذا وجدت)
	- mcopy -i $(ESP) \
		"المقلع/اعدادات_القائمة/تحديد.png" \
		"::المقلع/اعدادات_القائمة/تحديد.png"

	# نسخ صورة السهم (إذا وجدت)
	- mcopy -i $(ESP) \
		"المقلع/اعدادات_القائمة/سهم.png" \
		"::المقلع/اعدادات_القائمة/سهم.png"

	# نسخ شريط المهلة (إذا وجد)
	- mcopy -i $(ESP) \
		"المقلع/اعدادات_القائمة/شريط_المهلة.png" \
		"::المقلع/اعدادات_القائمة/شريط_المهلة.png"

	# نسخ جميع صور الأزرار من المسار الجديد
	-for f in المقلع/اعدادات_القائمة/زر_*.png; do \
		if [ -f "$$f" ]; then \
			base=$$(basename "$$f"); \
			echo "نسخ $$base"; \
			mcopy -i $(ESP) "$$f" "::المقلع/اعدادات_القائمة/$$base"; \
		fi \
	done

	# إنشاء مجلد الشعار داخل المسار الجديد
	mmd -i $(ESP) "::المقلع/اعدادات_القائمة/شعار_النظام"

	# نسخ جميع إطارات الشعار من المسار الجديد
	-for f in المقلع/اعدادات_القائمة/شعار_النظام/*.png; do \
		if [ -f "$$f" ]; then \
			base=$$(basename "$$f"); \
			mcopy -i $(ESP) "$$f" "::المقلع/اعدادات_القائمة/شعار_النظام/$$base"; \
		fi \
	done

# ====================================
# بناء ISO لنظام UEFI
# ====================================
$(ISO): $(BOOTX64) $(ESP)
	rm -rf iso_build

	mkdir -p iso_build/EFI/BOOT

	cp $(BOOTX64) iso_build/EFI/BOOT/BOOTX64.EFI

	# نسخ مجلد المقلع بالكامل مع جميع محتوياته إلى صورة الـ ISO
	cp -r المقلع iso_build/

	cp $(ESP) iso_build/efiboot.img

	xorriso \
		-as mkisofs \
		-R \
		-J \
		-joliet-long \
		-input-charset utf-8 \
		-V "ArabOS" \
		-eltorito-alt-boot \
		-e efiboot.img \
		-no-emul-boot \
		-o $(ISO) \
		iso_build

	rm -rf iso_build

# ====================================
# نسخ متغيرات OVMF
# ====================================
$(OVMF_VARS):
	cp /usr/share/OVMF/OVMF_VARS_4M.fd $(OVMF_VARS)

# ====================================
# تشغيل صورة FAT
# ====================================
run: $(ESP) $(OVMF_VARS)
	qemu-system-x86_64 \
		-machine q35 \
		-m 512M \
		-drive if=pflash,format=raw,readonly=on,file=$(OVMF_CODE) \
		-drive if=pflash,format=raw,file=$(OVMF_VARS) \
		-drive format=raw,file=$(ESP)

# ====================================
# تشغيل ISO
# ====================================
runiso: $(ISO) $(OVMF_VARS)
	qemu-system-x86_64 \
		-machine q35 \
		-m 512M \
		-drive if=pflash,format=raw,readonly=on,file=$(OVMF_CODE) \
		-drive if=pflash,format=raw,file=$(OVMF_VARS) \
		-cdrom $(ISO)

# ====================================
# إنشاء الصور الناقصة (مكان مؤقت)
# ====================================
create-images:
	@echo "إنشاء صور القائمة الافتراضية (في حالة عدم وجودها)"
	@mkdir -p المقلع/اعدادات_القائمة
	@mkdir -p المقلع/اعدادات_القائمة/شعار_النظام
	
	# إنشاء صورة سهم.png افتراضية (16x16 بكسل)
	@if [ ! -f "المقلع/اعدادات_القائمة/سهم.png" ]; then \
		echo "إنشاء سهم.png افتراضي..."; \
		convert -size 16x16 xc:none -fill white -draw "polygon 4,2 4,14 12,8" \
			المقلع/اعدادات_القائمة/سهم.png 2>/dev/null || \
		echo "⚠️  يرجى إنشاء المقلع/اعدادات_القائمة/سهم.png يدوياً (صورة PNG شفافة 16x16)"; \
	fi
	
	# إنشاء صورة شريط.png افتراضية
	@if [ ! -f "المقلع/اعدادات_القائمة/شريط.png" ]; then \
		echo "إنشاء شريط.png افتراضي..."; \
		convert -size 400x46 gradient:blue-darkblue \
			المقلع/اعدادات_القائمة/شريط.png 2>/dev/null || true; \
	fi
	
	# إنشاء صورة تحديد.png افتراضية
	@if [ ! -f "المقلع/اعدادات_القائمة/تحديد.png" ]; then \
		echo "إنشاء تحديد.png افتراضي..."; \
		convert -size 400x44 xc:'#1A6EBF' \
			المقلع/اعدادات_القائمة/تحديد.png 2>/dev/null || true; \
	fi
	
	# إنشاء صورة شريط_المهلة.png افتراضية
	@if [ ! -f "المقلع/اعدادات_القائمة/شريط_المهلة.png" ]; then \
		echo "إنشاء شريط_المهلة.png افتراضي..."; \
		convert -size 400x6 xc:'#44AAFF' \
			المقلع/اعدادات_القائمة/شريط_المهلة.png 2>/dev/null || true; \
	fi

# ====================================
# تنظيف الملفات
# ====================================
clean:
	rm -f *.o
	rm -f *.so
	rm -f *.EFI
	rm -f *.img
	rm -f *.iso
	rm -f $(OVMF_VARS)

# ====================================
# تعريفات الأهداف الوهمية
# ====================================
.PHONY: all run runiso clean create-images
